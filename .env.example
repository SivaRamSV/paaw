# =============================================================================
# PAAW Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://paaw:paaw@localhost:5432/paaw

# -----------------------------------------------------------------------------
# Cache (Valkey/Redis)
# -----------------------------------------------------------------------------
VALKEY_URL=valkey://localhost:6379

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------

# Anthropic (Claude) — recommended for PAAW
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-openai-key-here

# Groq (optional, fast & cheap)
# GROQ_API_KEY=gsk_your-groq-key-here

# Local LLM via Ollama or LM Studio (optional)
# OLLAMA_BASE_URL=http://localhost:11434

# Model configuration (defaults to Claude Sonnet 4.6)
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Channel Configuration (optional)
# -----------------------------------------------------------------------------

# Telegram Bot
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# Discord
# DISCORD_BOT_TOKEN=your-discord-bot-token

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
DEBUG=false

# Web UI
WEB_HOST=0.0.0.0
WEB_PORT=8080

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Secret key for sessions (generate with: openssl rand -hex 32)
# SECRET_KEY=your-secret-key-here
